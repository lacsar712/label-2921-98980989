generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  LIBRARIAN
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
}

enum SwapStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MessageType {
  SYSTEM
  INVENTORY_ALERT
  RESERVATION_PENDING
  INVENTORY_REVIEW
  PROCUREMENT_ARRIVAL
  CUSTOM
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TargetType {
  USER
  ROLE
  ALL_ADMINS
  ALL_LIBRARIANS
  ALL_USERS
}

enum SeriesType {
  MONOGRAPH
  TEXTBOOK
  JOURNAL_BOUND
  COLLECTION
  REFERENCE
  OTHER
}

enum PurchaseStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  PURCHASED
}

enum ProcurementRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIAL_APPROVED
}

enum ProcurementOrderStatus {
  CREATED
  ORDERED
  PARTIAL_ARRIVED
  FULLY_ARRIVED
  CANCELLED
  COMPLETED
}

enum ProcurementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InterLibraryLoanDirection {
  BORROW_IN
  LEND_OUT
}

enum InterLibraryLoanStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  IN_USE
  RETURNED
  REJECTED
}

enum FeePayer {
  OUR_LIBRARY
  OTHER_LIBRARY
  SPLIT
}

enum CompensationLossType {
  LOST
  DAMAGED
  STOLEN
}

enum CompensationStatus {
  PENDING
  INSTALLMENT
  SETTLED
  WAIVED
}

enum PaymentMethod {
  CASH
  WECHAT
  ALIPAY
  BANK_TRANSFER
  OTHER
}

enum ActivityType {
  LECTURE
  READING_CLUB
  EXHIBITION
}

enum ActivityStatus {
  DRAFT
  REGISTRATION_OPEN
  ONGOING
  ENDED
  CANCELLED
}

enum RegistrationStatus {
  REGISTERED
  WAITLIST
  CANCELLED
  CHECKED_IN
  NO_SHOW
}

model User {
  id              Int               @id @default(autoincrement())
  username        String            @unique
  password        String
  role            Role              @default(LIBRARIAN)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  schedules       Schedule[]
  requestedSwaps  ShiftSwapRequest[] @relation("RequestedSwaps")
  targetedSwaps   ShiftSwapRequest[] @relation("TargetedSwaps")
  sentMessages    Message[]         @relation("SentMessages")
  receivedReceipts MessageReceipt[] @relation("MessageReceipts")
  purchaseRequests PurchaseRequest[] @relation("RequestedBy")
  reviewedPurchases PurchaseRequest[] @relation("ReviewedBy")
  handledCompensations Compensation[] @relation("CompensationHandler")
  procurementRequests ProcurementRequest[] @relation("ProcurementRequester")
  reviewedProcurements ProcurementRequest[] @relation("ProcurementReviewer")
  createdProcurementOrders ProcurementOrder[] @relation("ProcurementOrderCreator")
  operatedArrivals ArrivalRecord[] @relation("ArrivalOperator")
  stockInArrivals ArrivalRecordItem[] @relation("StockInOperator")
  operatedReturns ReturnRecord[] @relation("ReturnOperator")
  createdActivities Activity[]
  createdInterLibraryLoans InterLibraryLoan[] @relation("ILLCreator")
  interLibraryLoanTimelines InterLibraryLoanTimeline[] @relation("ILLTimelineOperator")
  approvedILLExtensions InterLibraryLoanExtension[] @relation("ILLExtensionApprover")
  interLibraryLoanReminders InterLibraryLoanReminder[] @relation("ILLReminderOperator")
}

model Message {
  id            Int            @id @default(autoincrement())
  title         String
  content       String
  type          MessageType    @default(SYSTEM)
  priority      PriorityLevel  @default(MEDIUM)
  targetType    TargetType     @default(ALL_USERS)
  targetRole    Role?
  senderId      Int?
  sender        User?          @relation("SentMessages", fields: [senderId], references: [id])
  createdAt     DateTime       @default(now())
  receipts      MessageReceipt[] @relation("MessageReceipts")
}

model MessageReceipt {
  id         Int       @id @default(autoincrement())
  messageId  Int
  message    Message   @relation("MessageReceipts", fields: [messageId], references: [id], onDelete: Cascade)
  userId     Int
  user       User      @relation("MessageReceipts", fields: [userId], references: [id], onDelete: Cascade)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@unique([messageId, userId])
  @@index([userId, isRead])
}

model MessageTemplate {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  title     String
  content   String
  type      MessageType   @default(CUSTOM)
  priority  PriorityLevel @default(MEDIUM)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ServiceLocation {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  type      String     @default("READING_ROOM")
  schedules Schedule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Schedule {
  id               Int             @id @default(autoincrement())
  userId           Int
  user             User            @relation(fields: [userId], references: [id])
  date             DateTime
  shiftType        ShiftType
  serviceLocationId Int
  serviceLocation  ServiceLocation @relation(fields: [serviceLocationId], references: [id])
  isLeader         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  requesterSwaps   ShiftSwapRequest[] @relation("RequesterSchedule")
  targetSwaps      ShiftSwapRequest[] @relation("TargetSchedule")

  @@unique([userId, date, shiftType, serviceLocationId])
}

model ShiftSwapRequest {
  id                    Int        @id @default(autoincrement())
  requesterId           Int
  requester             User       @relation("RequestedSwaps", fields: [requesterId], references: [id])
  targetUserId          Int
  targetUser            User       @relation("TargetedSwaps", fields: [targetUserId], references: [id])
  requesterScheduleId   Int
  requesterSchedule     Schedule   @relation("RequesterSchedule", fields: [requesterScheduleId], references: [id])
  targetScheduleId      Int
  targetSchedule        Schedule   @relation("TargetSchedule", fields: [targetScheduleId], references: [id])
  reason                String
  status                SwapStatus @default(PENDING)
  reviewedBy            Int?
  reviewedAt            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Borrower {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  borrows   BorrowRecord[]
  ratings   BookRating[]
  reservations Reservation[]
  compensations Compensation[]
  activityRegistrations ActivityRegistration[]
  activityFeedbacks ActivityFeedback[]
}

model Category {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  books                   Book[]
  procurementRequestItems ProcurementRequestItem[]
  procurementOrderItems   ProcurementOrderItem[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  isbn        String   @unique
  stock       Int      @default(0)
  price       Float
  description String?
  coverUrl    String?
  location    String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  borrows     BorrowRecord[]
  ratings     BookRating[]
  reservations Reservation[]
  seriesVolume SeriesVolume?
  compensations Compensation[]
}

model BorrowRecord {
  id            Int           @id @default(autoincrement())
  bookId        Int
  book          Book          @relation(fields: [bookId], references: [id])
  borrowerId    Int
  borrower      Borrower      @relation(fields: [borrowerId], references: [id])
  borrowDate    DateTime      @default(now())
  returnDate    DateTime?
  status        String        @default("BORROWED")
  compensation  Compensation?
}

model Compensation {
  id                Int                 @id @default(autoincrement())
  borrowRecordId    Int                 @unique
  borrowRecord      BorrowRecord        @relation(fields: [borrowRecordId], references: [id])
  bookId            Int
  book              Book                @relation(fields: [bookId], references: [id])
  borrowerId        Int
  borrower          Borrower            @relation(fields: [borrowerId], references: [id])
  lossType          CompensationLossType
  status            CompensationStatus  @default(PENDING)
  bookPrice         Float
  multiplier        Float               @default(2.0)
  depreciationRate  Float               @default(0.0)
  calculatedAmount  Float
  adjustedAmount    Float?
  paidAmount        Float               @default(0.0)
  paymentMethod     PaymentMethod?
  handlerId         Int?
  handler           User?               @relation("CompensationHandler", fields: [handlerId], references: [id])
  note              String?
  settledAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status])
  @@index([borrowerId])
  @@index([bookId])
}

model BookRating {
  id         Int      @id @default(autoincrement())
  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower @relation(fields: [borrowerId], references: [id])
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookId, borrowerId])
}

model Reservation {
  id         Int      @id @default(autoincrement())
  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower @relation(fields: [borrowerId], references: [id])
  status     String   @default("PENDING") // PENDING, FULFILLED, CANCELLED
  queuePosition Int  @default(1)
  createdAt  DateTime @default(now())
  fulfilledAt DateTime?

  @@index([bookId, status])
  @@index([borrowerId, status])
}

model BookSeries {
  id                 Int            @id @default(autoincrement())
  name               String
  description        String?
  coverUrl           String?
  expectedTotalVolumes Int
  seriesType         SeriesType     @default(OTHER)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  volumes            SeriesVolume[]
  purchaseRequests   PurchaseRequest[]

  @@unique([name])
}

model SeriesVolume {
  id              Int             @id @default(autoincrement())
  seriesId        Int
  series          BookSeries      @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  bookId          Int?            @unique
  book            Book?           @relation(fields: [bookId], references: [id], onDelete: SetNull)
  volumeNumber    Int
  isMissing       Boolean         @default(false)
  purchaseStatus  PurchaseStatus  @default(NONE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseRequests PurchaseRequest[]

  @@unique([seriesId, volumeNumber])
  @@index([seriesId, volumeNumber])
}

model PurchaseRequest {
  id             Int            @id @default(autoincrement())
  seriesId       Int
  series         BookSeries     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  volumeId       Int
  volume         SeriesVolume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  requestedById  Int
  requestedBy    User           @relation("RequestedBy", fields: [requestedById], references: [id])
  status         PurchaseStatus @default(PENDING)
  reason         String?
  estimatedPrice Float?
  reviewedById   Int?
  reviewedBy     User?          @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  purchasedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([seriesId, status])
  @@index([volumeId, status])
}

model InterLibraryLoan {
  id                 Int                       @id @default(autoincrement())
  bookTitle          String
  isbn               String
  volumeCount        Int                       @default(1)
  partnerLibraryName String
  contactPerson      String
  contactPhone       String?
  trackingNumber     String?
  lendDate           DateTime?
  dueDate            DateTime?
  actualReturnDate   DateTime?
  feePayer           FeePayer                  @default(OUR_LIBRARY)
  direction          InterLibraryLoanDirection
  status             InterLibraryLoanStatus    @default(PENDING)
  remarks            String?
  rejectionReason    String?
  createdById        Int?
  createdBy          User?                     @relation("ILLCreator", fields: [createdById], references: [id])
  timelines          InterLibraryLoanTimeline[]
  extensions         InterLibraryLoanExtension[]
  reminders          InterLibraryLoanReminder[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([direction, status])
  @@index([partnerLibraryName])
  @@index([status, dueDate])
}

model InterLibraryLoanTimeline {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  status           InterLibraryLoanStatus?
  action           String
  operatorId       Int?
  operator         User?                   @relation("ILLTimelineOperator", fields: [operatorId], references: [id])
  note             String?
  timestamp        DateTime                @default(now())

  @@index([loanId])
}

model InterLibraryLoanExtension {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  originalDueDate  DateTime
  newDueDate       DateTime
  reason           String
  approvedById     Int?
  approvedBy       User?                   @relation("ILLExtensionApprover", fields: [approvedById], references: [id])
  status           String                  @default("PENDING")
  approvedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([loanId])
}

model InterLibraryLoanReminder {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  content          String
  operatorId       Int?
  operator         User?                   @relation("ILLReminderOperator", fields: [operatorId], references: [id])
  createdAt        DateTime                @default(now())

  @@index([loanId])
}

model ProcurementRequest {
  id              Int                       @id @default(autoincrement())
  requestNo       String                    @unique
  subject         String
  reason          String
  fundSubject     String
  status          ProcurementRequestStatus  @default(PENDING)
  requestedById   Int
  requestedBy     User                      @relation("ProcurementRequester", fields: [requestedById], references: [id])
  reviewedById    Int?
  reviewedBy      User?                     @relation("ProcurementReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNote      String?
  items           ProcurementRequestItem[]
  orders          ProcurementOrder[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([status])
  @@index([requestedById, status])
}

model ProcurementRequestItem {
  id              Int                 @id @default(autoincrement())
  requestId       Int
  request         ProcurementRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  title           String
  author          String
  isbn            String
  publisher       String
  requestedQty    Int
  estimatedPrice  Float
  priority        ProcurementPriority @default(MEDIUM)
  approvedQty     Int?
  adjustedNote    String?
  categoryId      Int?
  category        Category?           @relation(fields: [categoryId], references: [id])
  orderItems      ProcurementOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([requestId])
  @@index([isbn])
}

model ProcurementOrder {
  id                Int                     @id @default(autoincrement())
  orderNo           String                  @unique
  requestId         Int
  request           ProcurementRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supplier          String
  contactPerson     String?
  contactPhone      String?
  expectedArrival   DateTime?
  status            ProcurementOrderStatus  @default(CREATED)
  totalAmount       Float                   @default(0)
  createdById       Int
  createdBy         User                    @relation("ProcurementOrderCreator", fields: [createdById], references: [id])
  orderedAt         DateTime?
  completedAt       DateTime?
  items             ProcurementOrderItem[]
  arrivalRecords    ArrivalRecord[]
  returnRecords     ReturnRecord[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([status])
  @@index([requestId])
  @@index([expectedArrival])
}

model ProcurementOrderItem {
  id              Int                 @id @default(autoincrement())
  orderId         Int
  order           ProcurementOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestItemId   Int
  requestItem     ProcurementRequestItem @relation(fields: [requestItemId], references: [id])
  title           String
  author          String
  isbn            String
  publisher       String
  orderQty        Int
  unitPrice       Float
  receivedQty     Int                 @default(0)
  returnedQty     Int                 @default(0)
  stockInQty      Int                 @default(0)
  priority        ProcurementPriority @default(MEDIUM)
  categoryId      Int?
  category        Category?           @relation(fields: [categoryId], references: [id])
  arrivalItems    ArrivalRecordItem[]
  returnItems     ReturnRecordItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orderId])
  @@index([isbn])
}

model ArrivalRecord {
  id              Int                 @id @default(autoincrement())
  arrivalNo       String              @unique
  orderId         Int
  order           ProcurementOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  arrivalDate     DateTime            @default(now())
  totalReceived   Int                 @default(0)
  operatorId      Int
  operator        User                @relation("ArrivalOperator", fields: [operatorId], references: [id])
  remark          String?
  items           ArrivalRecordItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orderId])
  @@index([arrivalDate])
}

model ArrivalRecordItem {
  id              Int                 @id @default(autoincrement())
  arrivalRecordId Int
  arrivalRecord   ArrivalRecord       @relation(fields: [arrivalRecordId], references: [id], onDelete: Cascade)
  orderItemId     Int
  orderItem       ProcurementOrderItem @relation(fields: [orderItemId], references: [id])
  title           String
  isbn            String
  receivedQty     Int
  unitPrice       Float
  remark          String?
  stockInStatus   Boolean             @default(false)
  stockInAt       DateTime?
  stockInById     Int?
  stockInBy       User?               @relation("StockInOperator", fields: [stockInById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([arrivalRecordId])
  @@index([orderItemId])
}

model ReturnRecord {
  id              Int                 @id @default(autoincrement())
  returnNo        String              @unique
  orderId         Int
  order           ProcurementOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnDate      DateTime            @default(now())
  totalReturned   Int                 @default(0)
  totalRefund     Float               @default(0)
  operatorId      Int
  operator        User                @relation("ReturnOperator", fields: [operatorId], references: [id])
  reason          String?
  items           ReturnRecordItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orderId])
  @@index([returnDate])
}

model ReturnRecordItem {
  id              Int                 @id @default(autoincrement())
  returnRecordId  Int
  returnRecord    ReturnRecord        @relation(fields: [returnRecordId], references: [id], onDelete: Cascade)
  orderItemId     Int
  orderItem       ProcurementOrderItem @relation(fields: [orderItemId], references: [id])
  title           String
  isbn            String
  returnedQty     Int
  unitPrice       Float
  refundAmount    Float
  reason          String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([returnRecordId])
  @@index([orderItemId])
}

model Activity {
  id            Int                @id @default(autoincrement())
  title         String
  coverUrl      String?
  description   String
  type          ActivityType
  startTime     DateTime
  endTime       DateTime
  location      String
  onlineUrl     String?
  capacity      Int
  deadline      DateTime
  status        ActivityStatus     @default(DRAFT)
  createdById   Int
  createdBy     User               @relation(fields: [createdById], references: [id])
  registrations ActivityRegistration[]
  feedbacks     ActivityFeedback[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status])
  @@index([startTime])
}

model ActivityRegistration {
  id            Int                @id @default(autoincrement())
  activityId    Int
  activity      Activity           @relation(fields: [activityId], references: [id], onDelete: Cascade)
  borrowerId    Int
  borrower      Borrower           @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  status        RegistrationStatus @default(REGISTERED)
  queuePosition Int?
  registeredAt  DateTime           @default(now())
  cancelledAt   DateTime?
  checkInAt     DateTime?
  cancelReason  String?

  @@unique([activityId, borrowerId])
  @@index([activityId, status])
  @@index([borrowerId, status])
}

model ActivityFeedback {
  id         Int       @id @default(autoincrement())
  activityId Int
  activity   Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  borrowerId Int
  borrower   Borrower  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())

  @@unique([activityId, borrowerId])
}
