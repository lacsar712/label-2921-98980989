generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  LIBRARIAN
}

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
}

enum SwapStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MessageType {
  SYSTEM
  INVENTORY_ALERT
  RESERVATION_PENDING
  INVENTORY_REVIEW
  PROCUREMENT_ARRIVAL
  CUSTOM
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TargetType {
  USER
  ROLE
  ALL_ADMINS
  ALL_LIBRARIANS
  ALL_USERS
}

enum SeriesType {
  MONOGRAPH
  TEXTBOOK
  JOURNAL_BOUND
  COLLECTION
  REFERENCE
  OTHER
}

enum PurchaseStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  PURCHASED
}

enum InterLibraryLoanDirection {
  BORROW_IN
  LEND_OUT
}

enum InterLibraryLoanStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  IN_USE
  RETURNED
  REJECTED
}

enum FeePayer {
  OUR_LIBRARY
  OTHER_LIBRARY
  SPLIT
}

model User {
  id              Int               @id @default(autoincrement())
  username        String            @unique
  password        String
  role            Role              @default(LIBRARIAN)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  schedules       Schedule[]
  requestedSwaps  ShiftSwapRequest[] @relation("RequestedSwaps")
  targetedSwaps   ShiftSwapRequest[] @relation("TargetedSwaps")
  sentMessages    Message[]         @relation("SentMessages")
  receivedReceipts MessageReceipt[] @relation("MessageReceipts")
  purchaseRequests PurchaseRequest[] @relation("RequestedBy")
  reviewedPurchases PurchaseRequest[] @relation("ReviewedBy")
}

model Message {
  id            Int            @id @default(autoincrement())
  title         String
  content       String
  type          MessageType    @default(SYSTEM)
  priority      PriorityLevel  @default(MEDIUM)
  targetType    TargetType     @default(ALL_USERS)
  targetRole    Role?
  senderId      Int?
  sender        User?          @relation("SentMessages", fields: [senderId], references: [id])
  createdAt     DateTime       @default(now())
  receipts      MessageReceipt[] @relation("MessageReceipts")
}

model MessageReceipt {
  id         Int       @id @default(autoincrement())
  messageId  Int
  message    Message   @relation("MessageReceipts", fields: [messageId], references: [id], onDelete: Cascade)
  userId     Int
  user       User      @relation("MessageReceipts", fields: [userId], references: [id], onDelete: Cascade)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@unique([messageId, userId])
  @@index([userId, isRead])
}

model MessageTemplate {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  title     String
  content   String
  type      MessageType   @default(CUSTOM)
  priority  PriorityLevel @default(MEDIUM)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ServiceLocation {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  type      String     @default("READING_ROOM")
  schedules Schedule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Schedule {
  id               Int             @id @default(autoincrement())
  userId           Int
  user             User            @relation(fields: [userId], references: [id])
  date             DateTime
  shiftType        ShiftType
  serviceLocationId Int
  serviceLocation  ServiceLocation @relation(fields: [serviceLocationId], references: [id])
  isLeader         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  requesterSwaps   ShiftSwapRequest[] @relation("RequesterSchedule")
  targetSwaps      ShiftSwapRequest[] @relation("TargetSchedule")

  @@unique([userId, date, shiftType, serviceLocationId])
}

model ShiftSwapRequest {
  id                    Int        @id @default(autoincrement())
  requesterId           Int
  requester             User       @relation("RequestedSwaps", fields: [requesterId], references: [id])
  targetUserId          Int
  targetUser            User       @relation("TargetedSwaps", fields: [targetUserId], references: [id])
  requesterScheduleId   Int
  requesterSchedule     Schedule   @relation("RequesterSchedule", fields: [requesterScheduleId], references: [id])
  targetScheduleId      Int
  targetSchedule        Schedule   @relation("TargetSchedule", fields: [targetScheduleId], references: [id])
  reason                String
  status                SwapStatus @default(PENDING)
  reviewedBy            Int?
  reviewedAt            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Borrower {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  borrows   BorrowRecord[]
  ratings   BookRating[]
  reservations Reservation[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  isbn        String   @unique
  stock       Int      @default(0)
  price       Float
  description String?
  coverUrl    String?
  location    String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  borrows     BorrowRecord[]
  ratings     BookRating[]
  reservations Reservation[]
  seriesVolume SeriesVolume?
}

model BorrowRecord {
  id         Int       @id @default(autoincrement())
  bookId     Int
  book       Book      @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower  @relation(fields: [borrowerId], references: [id])
  borrowDate DateTime  @default(now())
  returnDate DateTime?
  status     String    @default("BORROWED") // BORROWED, RETURNED
}

model BookRating {
  id         Int      @id @default(autoincrement())
  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower @relation(fields: [borrowerId], references: [id])
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookId, borrowerId])
}

model Reservation {
  id         Int      @id @default(autoincrement())
  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
  borrowerId Int
  borrower   Borrower @relation(fields: [borrowerId], references: [id])
  status     String   @default("PENDING") // PENDING, FULFILLED, CANCELLED
  queuePosition Int  @default(1)
  createdAt  DateTime @default(now())
  fulfilledAt DateTime?

  @@index([bookId, status])
  @@index([borrowerId, status])
}

model BookSeries {
  id                 Int            @id @default(autoincrement())
  name               String
  description        String?
  coverUrl           String?
  expectedTotalVolumes Int
  seriesType         SeriesType     @default(OTHER)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  volumes            SeriesVolume[]
  purchaseRequests   PurchaseRequest[]

  @@unique([name])
}

model SeriesVolume {
  id              Int             @id @default(autoincrement())
  seriesId        Int
  series          BookSeries      @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  bookId          Int?
  book            Book?           @relation(fields: [bookId], references: [id], onDelete: SetNull)
  volumeNumber    Int
  isMissing       Boolean         @default(false)
  purchaseStatus  PurchaseStatus  @default(NONE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseRequests PurchaseRequest[]

  @@unique([seriesId, volumeNumber])
  @@index([seriesId, volumeNumber])
}

model PurchaseRequest {
  id             Int            @id @default(autoincrement())
  seriesId       Int
  series         BookSeries     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  volumeId       Int
  volume         SeriesVolume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  requestedById  Int
  requestedBy    User           @relation(fields: [requestedById], references: [id])
  status         PurchaseStatus @default(PENDING)
  reason         String?
  estimatedPrice Float?
  reviewedById   Int?
  reviewedBy     User?          @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  purchasedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([seriesId, status])
  @@index([volumeId, status])
}

model InterLibraryLoan {
  id                 Int                       @id @default(autoincrement())
  bookTitle          String
  isbn               String
  volumeCount        Int                       @default(1)
  partnerLibraryName String
  contactPerson      String
  contactPhone       String?
  trackingNumber     String?
  lendDate           DateTime?
  dueDate            DateTime?
  actualReturnDate   DateTime?
  feePayer           FeePayer                  @default(OUR_LIBRARY)
  direction          InterLibraryLoanDirection
  status             InterLibraryLoanStatus    @default(PENDING)
  remarks            String?
  rejectionReason    String?
  createdById        Int?
  createdBy          User?                     @relation(fields: [createdById], references: [id])
  timelines          InterLibraryLoanTimeline[]
  extensions         InterLibraryLoanExtension[]
  reminders          InterLibraryLoanReminder[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([direction, status])
  @@index([partnerLibraryName])
  @@index([status, dueDate])
}

model InterLibraryLoanTimeline {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  status           InterLibraryLoanStatus?
  action           String
  operatorId       Int?
  operator         User?                   @relation(fields: [operatorId], references: [id])
  note             String?
  timestamp        DateTime                @default(now())

  @@index([loanId])
}

model InterLibraryLoanExtension {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  originalDueDate  DateTime
  newDueDate       DateTime
  reason           String
  approvedById     Int?
  approvedBy       User?                   @relation(fields: [approvedById], references: [id])
  status           String                  @default("PENDING")
  approvedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([loanId])
}

model InterLibraryLoanReminder {
  id               Int                     @id @default(autoincrement())
  loanId           Int
  loan             InterLibraryLoan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  content          String
  operatorId       Int?
  operator         User?                   @relation(fields: [operatorId], references: [id])
  createdAt        DateTime                @default(now())

  @@index([loanId])
}
